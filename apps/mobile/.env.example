# PetPal Mobile - Environment Variables
# Copy this file to .env and fill in the values

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Cloudinary (for image uploads)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=petpal_uploads

# Feature Flags
EXPO_PUBLIC_ENABLE_SMS=false
EXPO_PUBLIC_ENABLE_LEADERBOARD=true

# Geofencing Defaults
EXPO_PUBLIC_DEFAULT_RADIUS_KM=5
EXPO_PUBLIC_MAX_RADIUS_KM=50

# Notification Timeouts
EXPO_PUBLIC_REMINDER_DAYS_BEFORE=3

# App Version
EXPO_PUBLIC_APP_VERSION=1.0.0
