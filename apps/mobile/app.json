{
  "expo": {
    "name": "PetPal",
    "slug": "petpal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.petpal.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PetPal needs your location to show nearby services and lost & found alerts.",
        "NSLocationAlwaysUsageDescription": "PetPal needs your location for radius-based alerts.",
        "NSCameraUsageDescription": "PetPal needs camera access to upload pet photos.",
        "NSPhotoLibraryUsageDescription": "PetPal needs photo library access to upload pet photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#10B981"
      },
      "package": "com.petpal.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#10B981",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PetPal to use your location."
        }
      ]
    ],
    "scheme": "petpal",
    "extra": {
      "eas": {
        "projectId": "petpal-mobile"
      }
    }
  }
}
